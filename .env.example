# UMMIA Environment Variables
# 
# Para desarrollo local, MSW intercepta las peticiones
# En producción, configurar estos valores para conectar con AWS

# GraphQL Endpoint (AppSync)
# VITE_APPSYNC_ENDPOINT=https://xxxxx.appsync-api.region.amazonaws.com/graphql

# AWS Region
# VITE_AWS_REGION=us-east-1

# Cognito User Pool
# VITE_USER_POOL_ID=us-east-1_xxxxx
# VITE_USER_POOL_CLIENT_ID=xxxxx

# API Key (si se usa en lugar de Cognito)
# VITE_API_KEY=xxxxx

# Modo de desarrollo (para habilitar MSW)
# VITE_ENABLE_MOCKS=true
